    Class "Relics" 
    BaseType "Urn Relic" "Amphora Relic" "Vase Relic" "Seal Relic" "Coffer Relic" "Tapestry Relic" "Incense Relic" 
    SetTextColor 150 219 237 
    SetBackgroundColor 40 60 65 255 
    SetBorderColor 150 219 237 
    SetFontSize 40
    MinimapIcon 1 Yellow Pentagon 
    CustomAlertSound "音效\遗物.mp3" 300
    DisableDropSound 

